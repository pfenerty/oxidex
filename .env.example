# OCIDex Configuration
PORT=8080
LOG_LEVEL=info
ENVIRONMENT=development
DATABASE_URL=postgres://ocidex:ocidex@localhost:5432/ocidex?sslmode=disable

# GitHub OAuth (required)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Callback URL must point to the API server, not the frontend
GITHUB_REDIRECT_URL=http://localhost:8080/auth/callback
# SESSION_SECRET must be at least 32 bytes (use: openssl rand -hex 32)
SESSION_SECRET=
SESSION_MAX_AGE_DAYS=7

# Frontend URL — post-OAuth redirect target after successful login
FRONTEND_URL=http://localhost:3000

# API base URL — optional; populates the OpenAPI servers block for tooling/docs
# API_BASE_URL=http://localhost:8080

# CORS — must NOT be '*' when AllowCredentials is true; must match FRONTEND_URL
CORS_ALLOWED_ORIGINS=http://localhost:3000

# NATS JetStream (optional — event relay for external subscribers)
# NATS_ENABLED=false
# NATS_URL=nats://localhost:4222
# NATS_STREAM_NAME=ocidex
# NATS_EVENT_TTL_HOURS=24

# OCI Registry Auto-Scan (Zot webhook)
# SCANNER_ENABLED=false
# ZOT_REGISTRY_ADDR=zot:5000
# ZOT_REGISTRY_INSECURE=false
# ZOT_WEBHOOK_SECRET=
# SCANNER_WORKERS=2
# SCANNER_QUEUE_SIZE=50
