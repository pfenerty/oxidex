# OCIDex Configuration
# Copy to .env and fill in required values.
# See docs/CONFIGURATION.md for full reference.

# ── Core ──────────────────────────────────────────────────────────────────────

PORT=8080
LOG_LEVEL=info
ENVIRONMENT=development

# Required. Migrations run automatically at startup.
DATABASE_URL=postgres://ocidex:ocidex@localhost:5432/ocidex?sslmode=disable

# ── Authentication (GitHub OAuth) ─────────────────────────────────────────────
# All three are required. The app will not start without them.
# Create an OAuth App at https://github.com/settings/developers

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Must be registered in your GitHub OAuth App.
# When accessing via Tailscale or a remote IP, set to that address, e.g.:
#   GITHUB_REDIRECT_URL=http://100.104.73.75:8080/auth/callback
GITHUB_REDIRECT_URL=http://localhost:8080/auth/callback

# Min 32 bytes. Generate with: openssl rand -hex 32
SESSION_SECRET=
SESSION_MAX_AGE_DAYS=7

# ── Frontend / CORS ───────────────────────────────────────────────────────────

# Post-login redirect target. Only the port matters; hostname is derived from
# the login request. Set to match wherever the frontend is served.
FRONTEND_URL=http://localhost:3000

# Must NOT be '*' when credentials are involved. Should match FRONTEND_URL.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional: populates the OpenAPI servers block for tooling/docs.
# API_BASE_URL=http://localhost:8080

# ── Database Pool ─────────────────────────────────────────────────────────────

# DATABASE_MAX_CONNECTIONS=10

# ── Enrichment Pipeline ───────────────────────────────────────────────────────
# In-process mode (default). Set ENRICHMENT_NATS_MODE=true for K8s scale-out.

ENRICHMENT_ENABLED=true
# ENRICHMENT_WORKERS=2
# ENRICHMENT_QUEUE_SIZE=100
# ENRICHMENT_NATS_MODE=false

# ── OCI Registry Scanner ──────────────────────────────────────────────────────
# Required for webhook-triggered and poll-triggered scanning.

SCANNER_ENABLED=false
# SCANNER_WORKERS=2
# SCANNER_QUEUE_SIZE=50
# SCANNER_NATS_MODE=false    # Set true for K8s scale-out via scanner-worker

# Enable background poller for poll/both scan-mode registries.
# Requires SCANNER_ENABLED=true.
# REGISTRY_POLLER_ENABLED=false

# ── NATS JetStream ────────────────────────────────────────────────────────────
# Optional. Used for the event relay and K8s scale-out worker modes.

# NATS_ENABLED=false
# NATS_URL=nats://localhost:4222
# NATS_STREAM_NAME=ocidex
# NATS_EVENT_TTL_HOURS=24
# NATS_STREAM_REPLICAS=1    # Set to 3 for a 3-node NATS cluster

# ── Audit Logging ─────────────────────────────────────────────────────────────

# AUDIT_LOG_ENABLED=true
